# ==============================================================================
# Gramps MCP runtime configuration
# ==============================================================================

# --- MCP server ---
HOST=127.0.0.1
PORT=8000
TRANSPORT=stdio # stdio | streamable-http | sse
MCP_TOOL_MODE=condensed # condensed | verbose | both | intent

# --- Gramps connection ---
# Supply GRAMPS_URL through runtime configuration.
# Supply GRAMPS_TOKEN through a runtime secret provider, or supply both
# GRAMPS_USERNAME and GRAMPS_PASSWORD through runtime secret references.
# TLS_PROFILE / TLS_PROFILES_REF select verified private trust when required.

# --- Telemetry and policy ---
ENABLE_OTEL=False
# OTEL_EXPORTER_OTLP_ENDPOINT is supplied at runtime.
# OTEL_EXPORTER_OTLP_HEADERS_REF=secret://telemetry/headers
# LANGFUSE_CAPTURE_CONTENT=false
EUNOMIA_TYPE=none # none | embedded | remote
# Supply the embedded policy path or remote URL at runtime when enabled.

# --- Optional domain toggles ---
BOOKMARKSTOOL=True
CHATTOOL=True
CITATIONSTOOL=True
CONFIGTOOL=True
DNATOOL=True
EVENTSTOOL=True
EXPORTERSTOOL=True
FACTSTOOL=True
FAMILIESTOOL=True
FILTERSTOOL=True
HOLIDAYSTOOL=True
IMPORTERSTOOL=True
LIVINGTOOL=True
MEDIATOOL=True
METADATATOOL=True
NAME_FORMATSTOOL=True
NAME_GROUPSTOOL=True
NOTESTOOL=True
OIDCTOOL=True
PEOPLETOOL=True
PLACESTOOL=True
RELATIONSTOOL=True
REPORTSTOOL=True
REPOSITORIESTOOL=True
SEARCHTOOL=True
SOURCESTOOL=True
TAGSTOOL=True
TASKSTOOL=True
TIMELINETOOL=True
TOKENTOOL=True
TRANSACTIONSTOOL=True
TRANSLATIONSTOOL=True
TREESTOOL=True
TYPESTOOL=True
USERSTOOL=True
