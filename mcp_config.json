{
  "mcpServers": {
    "gramps-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "gramps-mcp[mcp]",
        "gramps-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "GRAMPS_TOKEN": "env://GRAMPS_TOKEN",
        "GRAMPS_URL": "env://GRAMPS_URL"
      }
    }
  }
}
